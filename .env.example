# Firebase public client config. These are used by the browser app.
NEXT_PUBLIC_FIREBASE_API_KEY=your_public_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Keep false while testing. Set true only after Firebase rules + Stripe webhook are working.
NEXT_PUBLIC_REQUIRE_SUBSCRIPTIONS=false
NEXT_PUBLIC_INOUT_TRIAL_DAYS=0
NEXT_PUBLIC_ALL_APPS_TRIAL_DAYS=0

# Stripe server-side keys. Never expose these in client code.
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PRICE_INOUT_MONTHLY=price_your_inout_monthly_price_id
STRIPE_PRICE_ALL_APPS_MONTHLY=price_your_all_apps_monthly_price_id

# Public app URL, no trailing slash.
APP_BASE_URL=https://your-public-inout-domain.com

# Firebase service account JSON for webhook writes to users/{uid}/subscriptions/...
# Paste as one-line JSON in Vercel env vars. Do not commit real values.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your_project_id","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"firebase-adminsdk-...@your_project.iam.gserviceaccount.com","client_id":"...","token_uri":"https://oauth2.googleapis.com/token"}
